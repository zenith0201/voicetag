<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- App metadata -->
  <key>CFBundleName</key>
  <string>VoiceTag</string>
  <key>CFBundleIdentifier</key>
  <string>com.voicetag.app</string>
  <key>CFBundleVersion</key>
  <string>1</string>
  <key>CFBundleShortVersionString</key>
  <string>1.0.0</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>CFBundleExecutable</key>
  <string>VoiceTag</string>

  <!-- macOS minimum version -->
  <key>LSMinimumSystemVersion</key>
  <string>14.0</string>

  <!-- Required: Microphone access for voice recording -->
  <key>NSMicrophoneUsageDescription</key>
  <string>VoiceTag uses the microphone to capture your spoken tags for photo sorting.</string>

  <!-- Required: Photo library access (if using Photos integration) -->
  <key>NSPhotoLibraryUsageDescription</key>
  <string>VoiceTag can read from your Photos library for tagging.</string>

  <!-- File access -->
  <key>NSDocumentsFolderUsageDescription</key>
  <string>VoiceTag needs access to move and organize your photos.</string>

  <!-- App sandbox settings -->
  <key>com.apple.security.app-sandbox</key>
  <false/>

  <!-- Audio input -->
  <key>com.apple.security.device.audio-input</key>
  <true/>

  <!-- File system access -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
  <key>com.apple.security.files.downloads.read-write</key>
  <true/>

  <!-- High-resolution support -->
  <key>NSHighResolutionCapable</key>
  <true/>

  <!-- Supports retina displays -->
  <key>NSPrincipalClass</key>
  <string>NSApplication</string>
</dict>
</plist>
